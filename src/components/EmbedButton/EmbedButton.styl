.root
  margin-left 4px
  margin-top -10px

.content
  display flex
  flex-direction column
  gap 4px

  max-width 400px
  padding var(--indent-s)

  font-size 14px
  transition box-shadow 1s ease-out

  pre
    text-wrap wrap
    font-size 12px
    opacity .6
    max-height 100px
    overflow-y auto
    overflow-x hidden


  pre button
    // backdrop-filter: blur(10px)
    background-color var(--active-color-alpha-800)
    position absolute
    right 3px
    bottom 3px
    opacity 0
    transition opacity 0.1s ease-out

    &:hover
      background-color var(--active-color)

  &:hover button
    opacity 1

.isCopied
  animation copied 3s ease-out

@keyframes copied
  0%
    box-shadow inset 0 0 0 1px var(--active-color)
  100%
    box-shadow inset 0 0 0 1px var(--active-color-alpha-0)
